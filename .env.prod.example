# Produktions-Umgebungsvariablen — diese Datei als .env.prod speichern
# und NIEMALS ins Git committen (.gitignore bereits gesetzt).

# ── Datenbank ──────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=SICHERES_PASSWORT_HIER_EINTRAGEN
DATABASE_URL=postgresql://thermal:SICHERES_PASSWORT_HIER_EINTRAGEN@postgres:5432/thermal
REDIS_URL=redis://redis:6379/0

# ── OGN / APRS ────────────────────────────────────────────────────────────────
APRS_HOST=aprs.glidernet.org
APRS_PORT=14580
APRS_CALLSIGN=N0CALL
APRS_PASSCODE=-1
APRS_FILTER=r/48.0/11.0/600

# ── Thermik-Erkennung ─────────────────────────────────────────────────────────
CIRCLING_ROT_MIN=3.0
CIRCLING_VARIO_FPM_MIN=50.0
CIRCLING_VARIO_FPM_MAX=2000.0
CLUSTER_RADIUS_M=800.0
THERMAL_TTL_SECONDS=1500

# ── API ───────────────────────────────────────────────────────────────────────
WS_PUSH_INTERVAL_SECONDS=10.0
CORS_ORIGINS=["https://<DOMAIN>"]
