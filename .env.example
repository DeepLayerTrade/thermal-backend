# Kopiere nach .env und passe an. .env ist gitignored.

# OGN / APRS
APRS_HOST=aprs.glidernet.org
APRS_PORT=14580
APRS_CALLSIGN=N0CALL
APRS_PASSCODE=-1
APRS_FILTER=r/48.0/11.0/600

# Thermik-Erkennung
CIRCLING_ROT_MIN=3.0
CIRCLING_VARIO_FPM_MIN=50
CLUSTER_RADIUS_M=800
THERMAL_TTL_SECONDS=1500

# Persistenz (Phase 4)
REDIS_URL=redis://localhost:6379/0
DATABASE_URL=postgresql://thermal:thermal@localhost:5432/thermal

# API
WS_PUSH_INTERVAL_SECONDS=10
